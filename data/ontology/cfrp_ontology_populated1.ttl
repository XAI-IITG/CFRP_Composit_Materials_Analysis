# PZT-derived damage observations for L1S12
ex:L1S12_pzt_damage_0 a ex:DamageObservation ;
    ex:observationText "Baseline" ;
    ex:hasDelamination false .

ex:L1S12_pzt_damage_1 a ex:DamageObservation ;
    ex:observationText "ch1: A 0deg, ch2: M 0deg, ch3: S 0deg" ;
    ex:hasDelamination false .

ex:L1S12_pzt_damage_2 a ex:DamageObservation ;
    ex:observationText "6 short cracks observed" ;
    ex:hasDelamination false .

ex:L1S12_pzt_damage_10 a ex:DamageObservation ;
    ex:observationText "30 cracks observed. Delamination frew just a little" ;
    ex:crackCount 30 ;
    ex:hasDelamination true .

ex:L1S12_pzt_damage_1000 a ex:DamageObservation ;
    ex:observationText "39 cracks observed" ;
    ex:crackCount 39 ;
    ex:hasDelamination false .

ex:L1S12_pzt_damage_10000 a ex:DamageObservation ;
    ex:observationText "no strain gages - using for SHMiA" ;
    ex:hasDelamination false .

ex:L1S12_pzt_damage_20000 a ex:DamageObservation ;
    ex:observationText "57 cracks observed" ;
    ex:crackCount 57 ;
    ex:hasDelamination false .

ex:L1S12_pzt_damage_30000 a ex:DamageObservation ;
    ex:observationText "Delamination grew a little vertically" ;
    ex:hasDelamination true .

ex:L1S12_pzt_damage_70000 a ex:DamageObservation ;
    ex:observationText "Slight shift on data, probably dye effect or temperature" ;
    ex:hasDelamination false .


